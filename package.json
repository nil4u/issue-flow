{
  "name": "issue-flow-monorepo",
  "private": true,
  "description": "Issue Flow monorepo: plugin (label-based issue state machine and provider CLI) and console (dashboard API + web).",
  "license": "MIT",
  "workspaces": [
    "plugin",
    "console/api",
    "console/web"
  ],
  "scripts": {
    "dev": "node --env-file-if-exists=.env.dev console/scripts/dev.cjs",
    "db:up": "docker compose -f console/docker-compose.yml up -d postgres",
    "db:generate": "npm run db:generate -w issue-flow-console",
    "db:migrate:dev": "npm run db:migrate:dev -w issue-flow-console",
    "db:migrate": "npm run db:migrate -w issue-flow-console",
    "api": "npm run start -w issue-flow-console",
    "api:dev": "npm run dev -w issue-flow-console",
    "api:build": "npm run build -w issue-flow-console",
    "web": "node --env-file-if-exists=.env.dev console/scripts/web.cjs dev",
    "web:build": "node --env-file-if-exists=.env console/scripts/web.cjs build",
    "web:preview": "node --env-file-if-exists=.env console/scripts/web.cjs preview",
    "test": "node --test \"test/*.test.cjs\" && npm test -ws --if-present",
    "test:integration": "npm run test:integration -w issue-flow"
  }
}
