{
  "name": "issue-flow-console",
  "private": true,
  "version": "0.11.1",
  "description": "Issue Flow console: dashboard API for managed repositories and metrics.",
  "license": "MIT",
  "keywords": [
    "agentrix",
    "automation",
    "issue-flow"
  ],
  "scripts": {
    "dev": "node --env-file=../../.env.dev --watch --import tsx src/main.ts",
    "start": "NODE_ENV=production node dist/main.js",
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "test": "node --test \"test/*.test.cjs\"",
    "db:generate": "node --env-file-if-exists=../../.env.dev ../../node_modules/prisma/build/index.js generate",
    "db:migrate:dev": "node --env-file-if-exists=../../.env.dev ../../node_modules/prisma/build/index.js migrate dev",
    "db:migrate": "node --env-file-if-exists=../../.env ../../node_modules/prisma/build/index.js migrate deploy"
  },
  "dependencies": {
    "@agentrix/shared": "^2.44.0",
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xmz-ai/gitlab-webhook-bridge": "^0.1.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "~6"
  }
}
